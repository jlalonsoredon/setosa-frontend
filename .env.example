# Copy to `.env` or `.env.local` and adjust. Astro exposes only variables prefixed with `PUBLIC_` to the client.

# Set to "false" to hide the TensorFlow.js / COCO-SSD block on `/intel` (no model CDN download, smaller page).
# PUBLIC_FEATURE_INTEL_ML=false

# Set to "false" to hide the MapLibre map on `/map` and show a lightweight placeholder instead.
# PUBLIC_FEATURE_MAP=false

# Base URL of the traffic alert API.
# PUBLIC_ALERT_API_URL=https://setosa-te3e.onrender.com/api/v1
