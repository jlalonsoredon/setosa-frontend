---
/**
 * Stroke-only HUD brackets. Geometry is inset by half the stroke width in viewBox space
 * so outer edges sit on the host padding edge (flush with the inner side of a thin border).
 * Optional `bleedInset` nudges the whole layer inward when you still see overlap.
 */
interface Props {
  variant?: "primary" | "secondary";
  /** Extra offset from the host edge (applied to each corner SVG). */
  inset?: string;
  /** Inset the whole layer from the host padding edge when borders/glow still clip poorly. */
  bleedInset?: string;
  /** Arm length of each bracket */
  arm?: string;
  fixed?: boolean;
  glow?: boolean;
  class?: string;
}

const {
  variant = "primary",
  inset = "0",
  arm = "2rem",
  fixed = false,
  glow = true,
  bleedInset = "0",
  class: className,
} = Astro.props;

const colorClass = variant === "secondary" ? "text-sf-secondary" : "text-sf-primary";

const glowFilter =
  variant === "secondary"
    ? "drop-shadow(0 0 4px color-mix(in oklab, var(--sf-glow-secondary) 45%, transparent))"
    : "drop-shadow(0 0 4px color-mix(in oklab, var(--sf-glow-primary) 45%, transparent))";

const strokeWidth = 6;
const h = strokeWidth / 2;

/**
 * Top: vertical → chamfer → horizontal (outer stroke on top/left edges).
 * Bottom: same pattern mirrored (vertical from interior down, chamfer, horizontal on bottom).
 */
const corners = [
  {
    d: `M ${h} 100 L ${h} ${2 * h} L ${2 * h} ${h} L 100 ${h}`,
    style: { top: inset, left: inset, width: arm, height: arm },
  },
  {
    d: `M ${100 - h} 100 L ${100 - h} ${2 * h} L ${100 - 2 * h} ${h} L ${h} ${h}`,
    style: { top: inset, right: inset, width: arm, height: arm },
  },
  {
    d: `M ${h} 0 L ${h} ${100 - 2 * h} L ${2 * h} ${100 - h} L 100 ${100 - h}`,
    style: { bottom: inset, left: inset, width: arm, height: arm },
  },
  {
    d: `M ${100 - h} 0 L ${100 - h} ${100 - 2 * h} L ${100 - 2 * h} ${100 - h} L ${h} ${100 - h}`,
    style: { bottom: inset, right: inset, width: arm, height: arm },
  },
];

const baseSvgStyle = {
  filter: glow ? glowFilter : undefined,
};

const bleedStyle =
  bleedInset === "0"
    ? { top: 0, left: 0, right: 0, bottom: 0 }
    : { top: bleedInset, left: bleedInset, right: bleedInset, bottom: bleedInset };
---

<div
  class:list={["pointer-events-none", fixed ? "fixed" : "absolute", className]}
  style={bleedStyle}
  aria-hidden="true"
>
  {
    corners.map(({ d, style }) => (
      <svg
        class:list={["pointer-events-none absolute overflow-visible", colorClass]}
        style={{ ...style, ...baseSvgStyle }}
        viewBox="0 0 100 100"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d={d}
          class="stroke-current"
          stroke-width={strokeWidth}
          stroke-linecap="butt"
          stroke-linejoin="bevel"
        />
      </svg>
    ))
  }
</div>
