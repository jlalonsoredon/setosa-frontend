---
import HudMount from "./HudMount.astro";
import HudCorners from "./HudCorners.astro";
import HudReticle from "./HudReticle.astro";

interface Props {
  fixed?: boolean;
  corners?: boolean;
  reticle?: boolean;
  variant?: "primary" | "secondary";
  cornerGlow?: boolean;
  reticleScale?: number;
  class?: string;
}

const {
  fixed = false,
  corners = true,
  reticle = false,
  variant = "primary",
  cornerGlow = true,
  reticleScale = 1,
  class: className,
} = Astro.props;
---

<HudMount fixed={fixed} class={className}>
  {corners && (
    <HudCorners {fixed} {variant} glow={cornerGlow} />
  )}
  {reticle && (
    <HudReticle {fixed} {variant} scale={reticleScale} />
  )}
  <slot />
</HudMount>
