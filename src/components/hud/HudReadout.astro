---
interface Props {
  align?: "left" | "right";
  class?: string;
}

const { align = "left", class: className } = Astro.props;
---

<div
  class:list={[
    "pointer-events-none max-w-[11rem] rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_65%,transparent)] px-2.5 py-1.5 backdrop-blur-sm",
    align === "right" && "ml-auto text-right",
    className,
  ]}
>
  <div class="sf-u-label !text-[0.55rem] text-sf-dim">
    <slot name="label" />
  </div>
  <div class="font-sf-mono text-sm leading-tight tracking-[0.12em] text-sf-text">
    <slot />
  </div>
</div>
