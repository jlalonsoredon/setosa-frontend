---
interface Props {
  /** Pin to viewport (cockpit) vs. containing block */
  fixed?: boolean;
  class?: string;
}

const { fixed = false, class: className } = Astro.props;
---

<div
  class:list={[
    "pointer-events-none",
    fixed ? "fixed inset-0" : "absolute inset-0",
    className,
  ]}
  aria-hidden="true"
>
  <slot />
</div>
