---
interface Props {
  /** Seconds for one full marquee cycle */
  durationSec?: number;
  class?: string;
}

const { durationSec = 22, class: className } = Astro.props;
---

<div
  class:list={[
    "pointer-events-none overflow-hidden border-y border-(--sf-border-subtle) bg-[color-mix(in_oklab,var(--sf-bg-deep)_55%,transparent)]",
    className,
  ]}
  aria-hidden="true"
>
  <div
    class="sf-hud-ticker__track whitespace-nowrap"
    style={{ "--sf-ticker-duration": `${durationSec}s` }}
  >
    <span class="inline-flex items-center gap-10 pr-10 font-sf-mono text-[0.62rem] uppercase tracking-[0.24em] text-sf-muted">
      <slot />
      <slot />
      <slot />
      <slot />
    </span>
    <span class="inline-flex items-center gap-10 pr-10 font-sf-mono text-[0.62rem] uppercase tracking-[0.24em] text-sf-muted">
      <slot />
      <slot />
      <slot />
      <slot />
    </span>
  </div>
</div>
