---
interface Props {
  variant?: "primary" | "secondary";
  fixed?: boolean;
  /** Visual scale (CSS transform) */
  scale?: number;
  class?: string;
}

const {
  variant = "primary",
  fixed = false,
  scale = 1,
  class: className,
} = Astro.props;

const stroke = variant === "secondary" ? "var(--sf-color-secondary)" : "var(--sf-color-primary)";
---

<div
  class:list={[
    "pointer-events-none left-1/2 top-1/2",
    fixed ? "fixed" : "absolute",
    className,
  ]}
  style={{ transform: `translate(-50%, -50%) scale(${scale})` }}
  aria-hidden="true"
>
  <svg width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle
      cx="60"
      cy="60"
      r="38"
      stroke={stroke}
      stroke-opacity="0.35"
      stroke-width="1"
      vector-effect="non-scaling-stroke"></circle>
    <circle
      cx="60"
      cy="60"
      r="18"
      stroke={stroke}
      stroke-opacity="0.55"
      stroke-width="1"
      vector-effect="non-scaling-stroke"></circle>
    <path
      d="M60 8v16M60 96v16M8 60h16M96 60h16"
      stroke={stroke}
      stroke-opacity="0.7"
      stroke-width="1"
      vector-effect="non-scaling-stroke"></path>
    <path d="M60 52v16M52 60h16" stroke={stroke} stroke-opacity="0.9" stroke-width="1"></path>
  </svg>
</div>
