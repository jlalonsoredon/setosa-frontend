---
interface Props {
  position?: "top" | "bottom";
  fixed?: boolean;
  /** `overlay` = absolute strip; `inline` = sits in normal layout flow */
  mode?: "overlay" | "inline";
  variant?: "primary" | "secondary";
  class?: string;
}

const {
  position = "top",
  fixed = false,
  mode = "overlay",
  variant = "primary",
  class: className,
} = Astro.props;

const border =
  position === "top"
    ? "border-b border-[var(--sf-border-subtle)]"
    : "border-t border-[var(--sf-border-subtle)]";

const accent =
  variant === "secondary"
    ? "from-[color-mix(in_oklab,var(--sf-color-secondary)_12%,transparent)]"
    : "from-[color-mix(in_oklab,var(--sf-color-primary)_12%,transparent)]";
---

<div
  class:list={[
    "pointer-events-none z-10 w-full",
    mode === "overlay" && [
      fixed ? "fixed" : "absolute",
      "left-0 right-0",
      position === "top" && "top-0",
      position === "bottom" && "bottom-0",
    ],
    mode === "inline" && "relative",
    border,
    "bg-gradient-to-b",
    position === "bottom" && "bg-gradient-to-t",
    accent,
    "to-transparent backdrop-blur-sm",
    className,
  ]}
  aria-hidden="true"
>
  <div
    class="flex items-center gap-3 px-4 py-2 font-sf-mono text-[0.62rem] uppercase tracking-[0.22em] text-sf-muted"
  >
    <div class="min-w-0 flex-1 truncate">
      <slot name="left" />
    </div>
    <div class="shrink-0 text-sf-text">
      <slot name="center" />
    </div>
    <div class="min-w-0 flex-1 truncate text-right">
      <slot name="right" />
    </div>
  </div>
</div>
