---
const path = Astro.url.pathname;

const links = [
  { href: "/", label: "Alertas" },
] as const;

function isActive(href: string): boolean {
  if (href === "/") return path === "/" || path === "";
  return path === href || path.startsWith(href + "/");
}
---

<nav
  class="sticky top-0 z-45 -mx-4 border-b border-(--sf-border-subtle) bg-[color-mix(in_oklab,var(--sf-bg-deep)_82%,transparent)] px-4 py-3 backdrop-blur-sm sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8"
  aria-label="Primary"
>
  <div class="flex flex-nowrap items-center gap-2 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
    <span class="mr-2 font-sf-display text-[0.65rem] uppercase tracking-[0.22em] text-sf-muted">Setosa Alertas</span>
    {
      links.map((l) => (
        <a
          href={l.href}
          class:list={[
            "rounded-sm border px-3 py-1.5 text-[0.65rem] uppercase tracking-[0.18em] transition",
            "focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sf-primary",
            isActive(l.href)
              ? "border-(--sf-border-strong) bg-[color-mix(in_oklab,var(--sf-color-primary)_12%,transparent)] text-sf-text shadow-[0_0_16px_var(--sf-glow-primary)]"
              : "border-(--sf-border-subtle) bg-[color-mix(in_oklab,var(--sf-bg-elevated)_88%,transparent)] text-sf-muted hover:border-(--sf-border-strong) hover:text-sf-text",
          ]}
          data-sf-sound-hover
          data-sf-sound-click
          aria-current={isActive(l.href) ? "page" : undefined}
        >
          {l.label}
        </a>
      ))
    }
  </div>
</nav>
