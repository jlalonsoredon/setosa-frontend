---
import Scanlines from "../effects/Scanlines.astro";

interface Props {
  /** Center content in max-w-6xl for long prose layouts */
  narrow?: boolean;
}

const { narrow = false } = Astro.props;
---

<div class="sf-app-shell-bg relative overflow-x-hidden">
  <div class="sf-hud-vignette pointer-events-none fixed inset-0 z-25" aria-hidden="true"></div>
  <div class="sf-noise pointer-events-none fixed inset-0 z-26 mix-blend-overlay" aria-hidden="true"></div>
  <Scanlines fixed animated class="z-30" />

  <div
    class:list={[
      "relative z-35 flex min-h-0 w-full flex-col gap-10 pb-0",
      narrow ? "mx-auto max-w-6xl px-4 sm:px-8" : "px-4 sm:px-6 lg:px-8",
    ]}
  >
    <slot />
  </div>
</div>
<script>
  import "../../scripts/boot";
</script>
