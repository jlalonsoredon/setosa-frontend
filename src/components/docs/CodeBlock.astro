---
interface Props {
  code: string;
  lang?: string;
  /** Visually hidden label for screen readers */
  label?: string;
}

const { code, lang = "astro", label = "Code example" } = Astro.props;
---

<div
  class="overflow-hidden rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_92%,transparent)] shadow-[inset_0_1px_0_color-mix(in_oklab,white_6%,transparent)]"
>
  <div
    class="flex items-center justify-between border-b border-[var(--sf-border-subtle)] px-3 py-1.5 font-sf-mono text-[0.6rem] uppercase tracking-[0.2em] text-sf-dim"
  >
    <span class="sr-only">{label}</span>
    <span aria-hidden="true">{lang}</span>
  </div>
  <pre
    class="max-h-[min(24rem,55vh)] overflow-auto p-4 font-sf-mono text-[0.72rem] leading-relaxed text-sf-text [scrollbar-width:thin] [scrollbar-color:color-mix(in_oklab,var(--sf-color-primary)_35%,transparent)_transparent]"
  ><code>{code}</code></pre>
</div>
