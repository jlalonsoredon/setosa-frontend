---
import Frame from "../core/Frame.astro";
import Panel from "../core/Panel.astro";
import Text from "../core/Text.astro";
import Button from "../core/Button.astro";
import Glow from "../effects/Glow.astro";
import Scanlines from "../effects/Scanlines.astro";
import AnimatedBorder from "../effects/AnimatedBorder.jsx";
import HudMount from "../hud/HudMount.astro";
import HudCorners from "../hud/HudCorners.astro";
import HudReticle from "../hud/HudReticle.astro";
import HudBar from "../hud/HudBar.astro";
import HudTicker from "../hud/HudTicker.astro";
import HudReadout from "../hud/HudReadout.astro";
import HudFrame from "../hud/HudFrame.astro";
import Radar from "../radar/Radar.astro";
import Terminal from "../terminal/Terminal.astro";
import TerminalLine from "../terminal/TerminalLine.astro";
import TerminalPrompt from "../terminal/TerminalPrompt.astro";

interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

{
  slug === "frame" && (
    <Frame variant="primary" glow>
      <div class="sf-frame-content-inset p-4">
        <Text variant="label">Framed</Text>
        <p class="mt-1 text-sm text-sf-muted">Angled border with glow.</p>
      </div>
    </Frame>
  )
}

{
  slug === "panel" && (
    <Panel variant="primary" glow layer="raised">
      <Text variant="heading" as="h3" class="!text-base">
        Panel
      </Text>
      <p class="mt-2 text-sm text-sf-muted">Raised layer on a primary frame.</p>
    </Panel>
  )
}

{
  slug === "text" && (
    <div class="space-y-2">
      <Text variant="heading" as="h3">
        Status
      </Text>
      <Text variant="label">Subsystem</Text>
      <Text variant="data">00:14:22</Text>
    </div>
  )
}

{
  slug === "button" && (
    <div class="flex flex-wrap gap-3">
      <Button variant="primary" sound={false}>
        Confirm
      </Button>
      <Button variant="ghost" sound={false}>
        Quiet
      </Button>
    </div>
  )
}

{
  slug === "glow" && (
    <Glow mode="outer">
      <span class="inline-flex items-center rounded-sm bg-[color-mix(in_oklab,var(--sf-bg-elevated)_92%,transparent)] px-3 py-2 text-sm text-sf-text [text-shadow:0_0_8px_var(--sf-glow-primary)]">
        Highlighted block
      </span>
    </Glow>
  )
}

{
  slug === "scanlines" && (
    <div class="relative min-h-32 overflow-hidden rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_80%,transparent)]">
      <Scanlines animated />
      <div class="relative z-[3] p-4 text-sm text-sf-muted">Scanline overlay (local, animated).</div>
    </div>
  )
}

{
  slug === "animated-border" && (
    <AnimatedBorder client:visible>
      <div class="p-4 text-sm text-sf-muted">React island — border animates when visible.</div>
    </AnimatedBorder>
  )
}

{
  slug === "hud-mount" && (
    <div class="relative h-36 overflow-hidden rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_75%,transparent)]">
      <HudMount>
        <div class="absolute inset-0 flex items-center justify-center text-xs text-sf-dim">Mount layer (decorations stack here)</div>
      </HudMount>
    </div>
  )
}

{
  slug === "hud-corners" && (
    <div class="relative h-40 rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_78%,transparent)]">
      <HudCorners inset="0" arm="1.75rem" />
    </div>
  )
}

{
  slug === "hud-reticle" && (
    <div class="relative h-48 rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_78%,transparent)]">
      <HudReticle scale={0.75} />
    </div>
  )
}

{
  slug === "hud-bar" && (
    <div class="relative min-h-[4.5rem] overflow-hidden rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_80%,transparent)]">
      <HudBar mode="inline" position="top">
        <span slot="left">SEC-A</span>
        <span slot="center">LIVE</span>
        <span slot="right">OK</span>
      </HudBar>
      <p class="px-4 pb-3 pt-10 text-xs text-sf-dim">Inline status strip.</p>
    </div>
  )
}

{
  slug === "hud-ticker" && (
    <div class="overflow-hidden rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_82%,transparent)] py-2">
      <HudTicker durationSec={20}>
        <span>Telemetry nominal</span>
        <span>·</span>
        <span>Link stable</span>
        <span>·</span>
        <span>Telemetry nominal</span>
        <span>·</span>
        <span>Link stable</span>
      </HudTicker>
    </div>
  )
}

{
  slug === "hud-readout" && (
    <div class="flex justify-end">
      <HudReadout>
        <span slot="label">Pitch</span>
        +01.2°
      </HudReadout>
    </div>
  )
}

{
  slug === "hud-frame" && (
    <div class="relative h-40 overflow-hidden rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_75%,transparent)]">
      <HudFrame corners reticle reticleScale={0.55} variant="secondary" class="opacity-95" />
      <div class="pointer-events-none absolute inset-0 z-10 flex items-center justify-center text-center text-xs text-sf-muted">
        HUD frame + slot
      </div>
    </div>
  )
}

{
  slug === "radar" && (
    <div class="mx-auto max-w-xs">
      <Radar
        variant="primary"
        blips={[
          { angleDeg: 45, distance: 0.5 },
          { angleDeg: 200, distance: 0.65 },
        ]}
      />
    </div>
  )
}

{
  slug === "terminal" && (
    <Terminal title="SYS.LOG" bodyClass="max-h-44">
      <TerminalLine variant="output">Ready.</TerminalLine>
      <TerminalLine variant="system">Uplink verified.</TerminalLine>
    </Terminal>
  )
}

{
  slug === "terminal-line" && (
    <div class="space-y-1 rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_90%,transparent)] p-4 font-sf-mono text-sm">
      <TerminalLine variant="command">npm run build</TerminalLine>
      <TerminalLine variant="error">Build failed</TerminalLine>
    </div>
  )
}

{
  slug === "terminal-prompt" && (
    <div class="rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_90%,transparent)] p-4 font-sf-mono text-sm">
      <TerminalPrompt char=">" cursor>
        deploy --prod
      </TerminalPrompt>
    </div>
  )
}
