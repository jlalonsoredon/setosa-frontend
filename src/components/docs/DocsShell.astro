---
import DocsNav from "./DocsNav.astro";
---

<div class="lg:grid lg:grid-cols-[minmax(0,14.5rem)_1fr] lg:items-start lg:gap-10">
  <details
    id="docs-nav-details"
    class="mb-8 rounded-sm border border-(--sf-border-subtle) bg-[color-mix(in_oklab,var(--sf-bg-elevated)_55%,transparent)] lg:hidden [&>summary]:list-none [&>summary::-webkit-details-marker]:hidden"
  >
    <summary
      class="flex cursor-pointer items-center justify-between gap-2 p-3 font-sf-mono text-xs uppercase tracking-[0.2em] text-sf-muted transition hover:text-sf-text"
    >
      <span>Browse components</span>
      <span class="text-sf-dim" aria-hidden="true">▾</span>
    </summary>
    <div class="border-t border-(--sf-border-subtle) p-3 pt-2">
      <DocsNav />
    </div>
  </details>

  <aside class="mb-10 hidden lg:mb-0 lg:block">
    <DocsNav />
  </aside>

  <main class="min-w-0">
    <slot />
  </main>
</div>
