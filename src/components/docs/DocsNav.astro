---
import { componentDocGroups } from "../../data/component-docs";

const path = Astro.url.pathname;
const base = "/components";

function linkHref(slug: string): string {
  return `${base}/${slug}`;
}

function isActive(slug: string): boolean {
  return path === linkHref(slug) || path === `${linkHref(slug)}/`;
}
---

<nav class="space-y-6" aria-label="Component documentation">
  {
    componentDocGroups.map((group) => (
      <div>
        <p class="mb-2 font-sf-mono text-[0.6rem] uppercase tracking-[0.22em] text-sf-dim">{group.label}</p>
        <ul class="space-y-0.5 border-l border-(--sf-border-subtle) pl-3">
          {group.items.map((item) => (
            <li>
              <a
                href={linkHref(item.slug)}
                class:list={[
                  "block rounded-sm border-l-2 border-transparent py-1 pl-[calc(0.5rem-2px)] text-sm transition-colors duration-150",
                  "focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sf-primary",
                  isActive(item.slug)
                    ? "border-sf-primary bg-[color-mix(in_oklab,var(--sf-color-primary)_14%,transparent)] text-sf-text [text-shadow:0_0_10px_var(--sf-glow-primary)]"
                    : "text-sf-muted hover:border-[color-mix(in_oklab,var(--sf-color-primary)_40%,transparent)] hover:bg-[color-mix(in_oklab,var(--sf-color-primary)_8%,transparent)] hover:text-sf-text",
                ]}
                aria-current={isActive(item.slug) ? "page" : undefined}
                data-sf-sound-hover
                data-sf-sound-click
              >
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</nav>
