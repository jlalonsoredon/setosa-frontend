---
import Frame from "./Frame.astro";

interface Props {
  variant?: "primary" | "secondary";
  glow?: boolean;
  animated?: boolean;
  /** Layering: raised adds subtle lift + stronger border read */
  layer?: "base" | "raised";
  /** Glass / neumorphic sci-fi: frosted panel with inner highlight */
  glass?: boolean;
  class?: string;
}

const {
  variant = "primary",
  glow = false,
  animated = false,
  layer = "base",
  glass = false,
  class: className,
} = Astro.props;
---

<Frame {variant} {glow} {animated} class:list={["block", className]}>
  <div
    class:list={[
      "rounded-[2px]",
      glass ? "sf-glass-panel" : "bg-[color-mix(in_oklab,var(--sf-bg-panel-solid)_92%,transparent)]",
      layer === "raised" && "shadow-[0_12px_40px_color-mix(in_oklab,black_55%,transparent)]",
      !glass && "border border-[var(--sf-border-subtle)]/80",
      "p-4 sm:p-6",
    ]}
  >
    <slot />
  </div>
</Frame>
