---
interface Props {
  variant?: "primary" | "secondary";
  glow?: boolean;
  animated?: boolean;
  /** `angled` = sci-fi cut corners (SVG). `square` = true rectangle — best for terminals / dense text. */
  edges?: "angled" | "square";
  class?: string;
}

const {
  variant = "primary",
  glow = false,
  animated = false,
  edges = "angled",
  class: className,
} = Astro.props;

const square = edges === "square";
---

<div
  class:list={[
    "sf-frame",
    square && "sf-frame--square",
    variant === "secondary" && "sf-frame--secondary",
    glow && "sf-frame--glow",
    animated && "sf-frame--animated",
    className,
  ]}
>
  {
    !square && (
      <svg class="sf-frame__svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
        <path
          d="M 14 0.5 L 86 0.5 L 99.5 14 L 99.5 86 L 86 99.5 L 14 99.5 L 0.5 86 L 0.5 14 Z"
        />
      </svg>
    )
  }
  <div class="sf-frame__slot">
    <slot />
  </div>
</div>
