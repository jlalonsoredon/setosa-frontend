---
interface Props {
  variant?: "heading" | "label" | "data";
  as?: "h1" | "h2" | "h3" | "p" | "span";
  glow?: boolean;
  class?: string;
}

const { variant = "data", as, glow = false, class: className } = Astro.props;

const Tag =
  as ??
  (variant === "heading" ? "h2" : variant === "label" ? "span" : "p");
---

<Tag
  class:list={[
    variant === "heading" &&
      "font-sf-display text-balance text-lg sm:text-xl font-semibold tracking-[0.14em] uppercase text-sf-text",
    variant === "label" && "sf-u-label",
    variant === "data" && "sf-u-data text-[0.95rem] text-sf-text",
    glow && "sf-text-glow-soft",
    className,
  ]}
>
  <slot />
</Tag>
