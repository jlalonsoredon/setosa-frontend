---
interface Props {
  variant?: "primary" | "secondary" | "ghost";
  type?: "button" | "submit" | "reset";
  /** Adds `data-sf-sound-hover` / `data-sf-sound-click` when true (requires `bindDelegatedSound` in layout boot). */
  sound?: boolean;
  animatedBorder?: boolean;
  id?: string;
  class?: string;
}

const {
  variant = "primary",
  type = "button",
  sound = true,
  animatedBorder = false,
  id,
  class: className,
} = Astro.props;
---

<button
  id={id}
  type={type}
  data-sf-sound-hover={sound ? true : undefined}
  data-sf-sound-click={sound ? true : undefined}
  class:list={[
    "group relative isolate inline-flex min-h-10 items-center justify-center gap-2 px-5 py-2",
    "font-sf-mono text-xs uppercase tracking-[0.2em]",
    "transition-[transform,box-shadow,color,background-color] duration-200",
    "focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sf-primary",
    "active:scale-[0.98]",
    variant === "primary" && [
      "bg-[color-mix(in_oklab,var(--sf-color-primary)_18%,var(--sf-bg-elevated))]",
      "text-sf-text border border-[var(--sf-border-strong)]",
      "shadow-[0_0_0_1px_color-mix(in_oklab,var(--sf-color-primary)_25%,transparent),0_0_24px_var(--sf-glow-primary)]",
      "hover:shadow-[0_0_0_1px_var(--sf-color-primary),0_0_36px_var(--sf-glow-primary)]",
    ],
    variant === "secondary" && [
      "bg-[color-mix(in_oklab,var(--sf-color-secondary)_14%,var(--sf-bg-elevated))]",
      "text-sf-text border border-[color-mix(in_oklab,var(--sf-color-secondary)_45%,transparent)]",
      "shadow-[0_0_20px_var(--sf-glow-secondary)]",
      "hover:shadow-[0_0_32px_var(--sf-glow-secondary)]",
    ],
    variant === "ghost" && [
      "bg-transparent text-sf-muted border border-[var(--sf-border-subtle)]",
      "hover:text-sf-text hover:border-[var(--sf-border-strong)] hover:shadow-[0_0_18px_var(--sf-glow-primary)]",
    ],
    animatedBorder && "sf-btn--animated-border",
    className,
  ]}
>
  {
    animatedBorder && (
      <span
        class="pointer-events-none absolute inset-0 opacity-60 [mask-image:linear-gradient(110deg,transparent_0%,white_40%,white_60%,transparent_100%)] [mask-size:200%_100%] motion-safe:animate-[sf-shimmer_2.8s_linear_infinite] bg-gradient-to-r from-transparent via-[var(--sf-color-primary)]/35 to-transparent"
        aria-hidden="true"
      />
    )
  }
  <span class="relative z-[1]">
    <slot />
  </span>
</button>

<style>
  @keyframes sf-shimmer {
    0% {
      mask-position: 120% 0;
    }
    100% {
      mask-position: -20% 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sf-btn--animated-border > span:first-child {
      animation: none !important;
    }
  }
</style>
