---
export type RadarBlip = {
  /** Degrees clockwise from “up” (12 o’clock). */
  angleDeg: number;
  /** 0 = center, 1 = outer ring. */
  distance: number;
};

interface Props {
  variant?: "primary" | "secondary";
  animated?: boolean;
  /** Auto-render blips when no `blips` slot is provided */
  blips?: RadarBlip[];
  class?: string;
}

const {
  variant = "primary",
  animated = true,
  blips = [
    { angleDeg: 32, distance: 0.62 },
    { angleDeg: 118, distance: 0.38 },
    { angleDeg: 220, distance: 0.78 },
    { angleDeg: 305, distance: 0.52 },
  ],
  class: className,
} = Astro.props;

const hasBlipSlot = Astro.slots.has("blips");

function polar(angleDeg: number, distance: number) {
  const rad = (angleDeg * Math.PI) / 180;
  const r = Math.min(1, Math.max(0, distance)) * 42;
  return {
    x: 50 + Math.sin(rad) * r,
    y: 50 - Math.cos(rad) * r,
  };
}

const resolved = blips.map((b) => polar(b.angleDeg, b.distance));

const textClass =
  variant === "secondary" ? "text-sf-secondary" : "text-sf-primary";
---

<div
  class:list={["relative mx-auto aspect-square w-full max-w-[min(100%,20rem)]", textClass, className]}
  role="img"
  aria-label="Radar display"
>
  <svg
    class="h-full w-full overflow-visible"
    viewBox="0 0 100 100"
    xmlns="http://www.w3.org/2000/svg"
  >
    <circle
      cx="50"
      cy="50"
      r="45"
      fill="color-mix(in oklab, var(--sf-bg-deep) 88%, transparent)"
      stroke="currentColor"
      stroke-opacity="0.35"
      stroke-width="0.6"
      vector-effect="non-scaling-stroke"></circle>
    <circle
      cx="50"
      cy="50"
      r="30"
      fill="none"
      stroke="currentColor"
      stroke-opacity="0.22"
      stroke-width="0.5"
      vector-effect="non-scaling-stroke"></circle>
    <circle
      cx="50"
      cy="50"
      r="15"
      fill="none"
      stroke="currentColor"
      stroke-opacity="0.22"
      stroke-width="0.5"
      vector-effect="non-scaling-stroke"></circle>
    <line
      x1="50"
      y1="5"
      x2="50"
      y2="95"
      stroke="currentColor"
      stroke-opacity="0.18"
      stroke-width="0.45"
      vector-effect="non-scaling-stroke"></line>
    <line
      x1="5"
      y1="50"
      x2="95"
      y2="50"
      stroke="currentColor"
      stroke-opacity="0.18"
      stroke-width="0.45"
      vector-effect="non-scaling-stroke"></line>
    <line
      x1="15"
      y1="15"
      x2="85"
      y2="85"
      stroke="currentColor"
      stroke-opacity="0.12"
      stroke-width="0.4"
      vector-effect="non-scaling-stroke"></line>
    <line
      x1="85"
      y1="15"
      x2="15"
      y2="85"
      stroke="currentColor"
      stroke-opacity="0.12"
      stroke-width="0.4"
      vector-effect="non-scaling-stroke"></line>

    <g transform="translate(50 50)">
      <g class:list={[animated && "sf-radar__sweep"]}>
        <path
          d="M 0 0 L 0 -44 A 44 44 0 0 1 10 -43"
          fill="color-mix(in oklab, currentColor 18%, transparent)"
          opacity="0.55"
          stroke="currentColor"
          stroke-opacity="0.35"
          stroke-width="0.35"
          vector-effect="non-scaling-stroke"></path>
        <line
          x1="0"
          y1="0"
          x2="0"
          y2="-44"
          stroke="currentColor"
          stroke-opacity="0.85"
          stroke-width="0.7"
          vector-effect="non-scaling-stroke"></line>
      </g>
    </g>

    {
      hasBlipSlot ? (
        <slot name="blips" />
      ) : (
        resolved.map((p) => (
          <circle
            cx={p.x}
            cy={p.y}
            r="1.6"
            fill="currentColor"
            class="opacity-90 [filter:drop-shadow(0_0_4px_var(--sf-glow-primary))]"
          />
        ))
      )
    }
  </svg>
</div>
