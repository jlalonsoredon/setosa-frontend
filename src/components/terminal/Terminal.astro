---
import Frame from "../core/Frame.astro";
import Text from "../core/Text.astro";

interface Props {
  title?: string;
  variant?: "primary" | "secondary";
  glow?: boolean;
  /** Max height of scrollable body (Tailwind class) */
  bodyClass?: string;
  class?: string;
}

const {
  title = "SYS.CONSOLE",
  variant = "primary",
  glow = true,
  bodyClass = "max-h-56 sm:max-h-64",
  class: className,
} = Astro.props;
---

<Frame {variant} {glow} edges="square" class:list={["block w-full min-w-0", className]}>
  <div
    class="flex min-h-0 w-full min-w-0 flex-col overflow-hidden rounded-none bg-[color-mix(in_oklab,var(--sf-bg-deep)_92%,transparent)]"
  >
    <div
      class="flex min-w-0 shrink-0 items-center gap-2 border-b border-[var(--sf-border-subtle)] px-3 py-2"
      role="toolbar"
    >
      <span class="flex shrink-0 gap-1.5" aria-hidden="true">
        <span class="h-2 w-2 rounded-full bg-red-500/80"></span>
        <span class="h-2 w-2 rounded-full bg-amber-400/80"></span>
        <span class="h-2 w-2 rounded-full bg-emerald-400/80"></span>
      </span>
      <Text
        variant="label"
        class="block min-w-0 flex-1 truncate !text-[0.6rem] tracking-[0.26em] text-sf-muted"
      >
        {title}
      </Text>
    </div>
    <div
      class:list={[
        "sf-terminal-body min-h-0 min-w-0 w-full overflow-x-auto overflow-y-auto p-3 font-sf-mono text-[0.78rem] leading-relaxed text-sf-text",
        "[scrollbar-width:thin]",
        "[scrollbar-color:color-mix(in_oklab,var(--sf-color-primary)_35%,transparent)_transparent]",
        bodyClass,
      ]}
    >
      <div class="w-full min-w-0 space-y-1">
        <slot />
      </div>
    </div>
  </div>
</Frame>
