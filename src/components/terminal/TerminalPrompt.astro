---
interface Props {
  char?: string;
  /** Blinking block cursor (CSS only) */
  cursor?: boolean;
  class?: string;
}

const { char = "›", cursor = false, class: className } = Astro.props;
---

<span class:list={["inline-flex max-w-full min-w-0 flex-wrap items-baseline gap-1 text-sf-primary", className]}>
  <span class="shrink-0 select-none opacity-80" aria-hidden="true">{char}</span>
  <span class:list={["min-w-0 flex-1 [min-inline-size:0]", cursor && "sf-terminal-cursor"]}>
    <slot />
  </span>
</span>
