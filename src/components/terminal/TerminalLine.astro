---
interface Props {
  variant?: "command" | "output" | "error" | "system" | "dim" | "highlight";
  class?: string;
}

const { variant = "output", class: className } = Astro.props;

const tone: Record<NonNullable<typeof variant>, string> = {
  command: "text-sf-primary",
  output: "text-sf-text",
  error: "text-red-400",
  system: "text-sf-secondary",
  dim: "text-sf-dim",
  highlight: "text-sf-text [text-shadow:0_0_10px_var(--sf-glow-primary)]",
};
---

<div
  class:list={[
    "w-full min-w-0 whitespace-pre-wrap break-words font-sf-mono text-[0.78rem] leading-relaxed [overflow-wrap:anywhere]",
    tone[variant],
    className,
  ]}
>
  <slot />
</div>
