---
interface Props {
  /** Cover the whole viewport (HUD) or only the positioned parent */
  fixed?: boolean;
  animated?: boolean;
  class?: string;
}

const { fixed = false, animated = false, class: className } = Astro.props;
---

<div
  class:list={[
    "sf-scanlines pointer-events-none",
    fixed && "fixed inset-0 z-[40]",
    !fixed && "absolute inset-0 z-[2]",
    animated && "sf-scanlines--animated",
    className,
  ]}
  aria-hidden="true"
>
</div>
