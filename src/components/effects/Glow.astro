---
interface Props {
  /** Outer box glow (default) or inset glow */
  mode?: "outer" | "inner";
  class?: string;
}

const { mode = "outer", class: className } = Astro.props;
---

<div
  class:list={[
    "rounded-[inherit]",
    mode === "outer" && "sf-u-glow-outer",
    mode === "inner" && "sf-u-glow-inner",
    className,
  ]}
>
  <slot />
</div>
