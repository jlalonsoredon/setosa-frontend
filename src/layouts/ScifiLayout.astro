---
import "../styles/global.css";

interface Props {
  title?: string;
  /** Short summary for `<meta name="description">` and social cards */
  description?: string;
}

const {
  title = "Sci‑Fi UI — Astro kit",
  description = "Astro-first sci‑fi UI kit: frames, HUD, terminal, radar, Tailwind v4, optional React for charts, maps, and motion.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.url.origin);
const ogImage = new URL("/og-image.png", Astro.url.origin);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:alt" content="Astro Scifi-UI — gradient title card" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;600;700&family=Share+Tech+Mono&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        var d = document.documentElement;
        try {
          var raw = localStorage.getItem("sf:settings");
          var s = raw ? JSON.parse(raw) : null;
          if (!s) {
            var leg = localStorage.getItem("sf-theme");
            if (leg && leg !== "default") d.setAttribute("data-theme", leg);
            d.removeAttribute("data-sf-appearance");
            d.setAttribute("data-sf-scanlines", "on");
            d.setAttribute("data-sf-grain", "on");
            d.setAttribute("data-sf-vignette", "on");
            d.setAttribute("data-sf-animations", "on");
            return;
          }
          var th = s.theme || "default";
          if (th !== "default") d.setAttribute("data-theme", th);
          else d.removeAttribute("data-theme");
          var ap = s.appearance || "default";
          if (ap !== "default") d.setAttribute("data-sf-appearance", ap);
          else d.removeAttribute("data-sf-appearance");
          d.setAttribute("data-sf-scanlines", s.scanlines === false ? "off" : "on");
          d.setAttribute("data-sf-grain", s.grain === false ? "off" : "on");
          d.setAttribute("data-sf-vignette", s.vignette === false ? "off" : "on");
          d.setAttribute("data-sf-animations", s.animations === false ? "off" : "on");
        } catch (e) {
          /* ignore */
        }
      })();
    </script>
  </head>
  <body class="min-h-dvh bg-sf-bg font-sf-mono text-sf-text antialiased">
    <slot />
  </body>
</html>
