---
import ScifiLayout from "../layouts/ScifiLayout.astro";
import AppShell from "../components/shell/AppShell.astro";
import AppNav from "../components/shell/AppNav.astro";
import Panel from "../components/core/Panel.astro";
import Text from "../components/core/Text.astro";
import Button from "../components/core/Button.astro";
import Frame from "../components/core/Frame.astro";
import Glow from "../components/effects/Glow.astro";
import AnimatedBorder from "../components/effects/AnimatedBorder.jsx";
import HudMount from "../components/hud/HudMount.astro";
import HudCorners from "../components/hud/HudCorners.astro";
import HudReticle from "../components/hud/HudReticle.astro";
import HudBar from "../components/hud/HudBar.astro";
import HudTicker from "../components/hud/HudTicker.astro";
import HudReadout from "../components/hud/HudReadout.astro";
import HudFrame from "../components/hud/HudFrame.astro";
import Radar from "../components/radar/Radar.astro";
import Terminal from "../components/terminal/Terminal.astro";
import TerminalLine from "../components/terminal/TerminalLine.astro";
import TerminalPrompt from "../components/terminal/TerminalPrompt.astro";
---

<ScifiLayout title="Component kit — Sci‑Fi UI">
  <AppShell>
    <AppNav />
    <header class="mb-10 space-y-3">
      <Text variant="label" class="text-sf-primary">Live samples</Text>
      <Text variant="heading" glow class="max-w-2xl">Composable primitives</Text>
      <p class="max-w-2xl text-sm leading-relaxed text-sf-muted">
        Frames, panels, HUD, radar, and terminal — static first, islands only where noted. Configure the shell on{" "}
        <a class="text-sf-primary underline decoration-[var(--sf-border-subtle)] underline-offset-2" href="/settings"
          >Settings</a
        >.
      </p>
    </header>

    <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <Panel variant="primary" glow animated layer="raised">
        <div class="flex flex-col gap-6">
          <div class="flex flex-wrap items-baseline justify-between gap-3">
            <Text variant="heading" as="h2" class="!text-base sm:!text-lg">Command panel</Text>
            <Text variant="label" class="text-sf-secondary">Live preview</Text>
          </div>
          <div class="grid gap-4 sm:grid-cols-3">
            <div class="rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_70%,transparent)] p-3">
              <Text variant="label">Signal</Text>
              <p class="mt-2 font-sf-mono text-2xl tracking-wide text-sf-text">98.4<span class="text-sf-muted">%</span></p>
            </div>
            <div class="rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_70%,transparent)] p-3">
              <Text variant="label">Latency</Text>
              <p class="mt-2 font-sf-mono text-2xl tracking-wide text-sf-text">12<span class="text-base text-sf-muted">ms</span></p>
            </div>
            <div class="rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_70%,transparent)] p-3">
              <Text variant="label">Nodes</Text>
              <p class="mt-2 font-sf-mono text-2xl tracking-wide text-sf-text">06</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-3">
            <Button variant="primary" animatedBorder>Initialize</Button>
            <Button variant="secondary">Override</Button>
            <Button variant="ghost" sound={false}>No sound</Button>
          </div>
          <Text variant="label" class="text-sf-dim">
            Buttons use audio cues by default; disable with <code class="text-sf-primary">sound=&#123;false&#125;</code>.
          </Text>
        </div>
      </Panel>

      <div class="flex flex-col gap-6">
        <Panel variant="secondary" glass glow>
          <div class="space-y-4">
            <Text variant="heading" as="h2" class="!text-base sm:!text-lg">Glass stack</Text>
            <Text variant="data" class="text-sf-muted">
              Layered depth with frost, inner highlight, and token-driven borders — no global state.
            </Text>
            <Glow mode="inner" class="rounded-sm p-4">
              <Text variant="label">Inner glow wrapper</Text>
              <p class="mt-2 text-sm text-sf-text">Compose <code class="text-sf-primary">Glow</code> around any slot content.</p>
            </Glow>
          </div>
        </Panel>

        <Frame variant="primary" glow class="block">
          <div class="sf-frame-content-inset">
            <AnimatedBorder client:visible>
              <div class="space-y-2 p-5">
                <Text variant="label" class="text-sf-primary">React island</Text>
                <Text variant="data" class="text-sf-muted">
                  Angled <code class="text-sf-primary">Frame</code> stays visible: wrap square islands with{" "}
                  <code class="text-sf-primary">sf-frame-content-inset</code> so opaque children do not cover the chamfered SVG
                  border. Framer Motion drives the conic border; the interior stays static HTML from Astro.
                </Text>
              </div>
            </AnimatedBorder>
          </div>
        </Frame>
      </div>
    </section>

    <section class="mt-10 grid gap-6 lg:grid-cols-2">
      <Panel variant="secondary" animated>
        <Text variant="heading" as="h2" class="mb-4 !text-base">Typography</Text>
        <div class="space-y-4">
          <div>
            <Text variant="label">Heading</Text>
            <Text variant="heading" as="h3" class="mt-1 !normal-case !tracking-normal !text-sf-text">
              Orbitron display
            </Text>
          </div>
          <div>
            <Text variant="label">Label</Text>
            <Text variant="label" class="mt-1 !text-sf-text">Uppercase microcopy</Text>
          </div>
          <div>
            <Text variant="label">Data</Text>
            <Text variant="data" class="mt-1 text-sf-primary">00:14:22:09</Text>
          </div>
        </div>
      </Panel>

      <Panel variant="primary">
        <Text variant="heading" as="h2" class="mb-4 !text-base">Frames only</Text>
        <div class="grid gap-4 sm:grid-cols-2">
          <Frame variant="primary" glow>
            <div class="p-4 text-sm text-sf-muted">Primary frame + glow</div>
          </Frame>
          <Frame variant="secondary" animated>
            <div class="p-4 text-sm text-sf-muted">Secondary frame + shimmer</div>
          </Frame>
        </div>
      </Panel>
    </section>

    <section class="mt-10 space-y-4">
      <Text variant="label" class="text-sf-secondary">Tactical kit</Text>
      <Text variant="heading" as="h2" class="!text-lg sm:!text-xl">HUD · radar · terminals</Text>
      <p class="max-w-3xl text-sm text-sf-muted">
        Compose cockpit layers with <code class="text-sf-primary">HudMount</code>, bracket corners, reticle, and status strips — then
        drop a passive <code class="text-sf-primary">Radar</code> or log output in a framed <code class="text-sf-primary">Terminal</code>.
        All static except your existing islands.
      </p>

      <div class="mt-8 grid gap-6 lg:grid-cols-2">
        <Panel variant="primary" glow layer="raised">
          <Text variant="heading" as="h2" class="mb-4 !text-base">HUD compose</Text>
          <div
            class="relative grid min-h-[22rem] grid-rows-[auto_1fr_auto] overflow-hidden rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_82%,transparent)]"
          >
            <HudMount class="col-span-full row-start-1 row-end-4">
              <HudCorners inset="0.85rem" arm="1.65rem" />
              <HudReticle scale={0.72} />
            </HudMount>

            <HudBar mode="inline" position="top" variant="primary" class="relative z-20">
              <span slot="left">SEC-07 · LKO</span>
              <span slot="center">VISUAL</span>
              <span slot="right">RNG 4.2</span>
            </HudBar>

            <div class="relative z-10 flex items-center justify-center px-4 py-6">
              <Radar
                class="w-full max-w-[13rem]"
                blips={[
                  { angleDeg: 18, distance: 0.55 },
                  { angleDeg: 140, distance: 0.42 },
                  { angleDeg: 260, distance: 0.7 },
                ]}
              />
            </div>

            <div class="pointer-events-none absolute left-3 top-14 z-20 max-w-[40%]">
              <HudReadout>
                <span slot="label">Pitch</span>
                +02.4°
              </HudReadout>
            </div>
            <div class="pointer-events-none absolute right-3 top-14 z-20 max-w-[40%]">
              <HudReadout align="right">
                <span slot="label">Yaw</span>
                184.0°
              </HudReadout>
            </div>

            <HudTicker class="relative z-20" durationSec={24}>
              <span>Telemetry nominal</span>
              <span>·</span>
              <span>IFF standby</span>
              <span>·</span>
              <span>Link encrypted</span>
              <span>·</span>
              <span>No fly-zone buffer 1200m</span>
            </HudTicker>
          </div>
          <Text variant="label" class="mt-3 text-sf-dim">
            Shortcut: <code class="text-sf-primary">HudFrame</code> bundles mount + corners + optional reticle for full-screen overlays.
          </Text>
          <div class="mt-4 rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_75%,transparent)] p-3">
            <Text variant="label" class="mb-2">HudFrame preview</Text>
            <div class="relative h-40 overflow-hidden rounded-sm">
              <HudFrame corners reticle reticleScale={0.55} variant="secondary" class="opacity-95" />
              <div
                class="pointer-events-none absolute inset-0 z-10 flex items-center justify-center text-center text-xs text-sf-muted"
              >
                Empty slot — add alerts, maps, video…
              </div>
            </div>
          </div>
        </Panel>

        <div class="flex flex-col gap-6">
          <Panel variant="secondary" animated>
            <Text variant="heading" as="h2" class="mb-4 !text-base">Secondary radar</Text>
            <Radar
              variant="secondary"
              animated={true}
              blips={[
                { angleDeg: 55, distance: 0.33 },
                { angleDeg: 190, distance: 0.61 },
                { angleDeg: 332, distance: 0.48 },
              ]}
            />
            <Text variant="label" class="mt-3 text-sf-dim">
              Pass the <code class="text-sf-secondary">blips</code> prop, or add children with{" "}
              <code class="text-sf-secondary">slot=&quot;blips&quot;</code> for custom SVG markers.
            </Text>
          </Panel>
        </div>

        <div class="min-w-0 lg:col-span-2">
          <Terminal title=" uplink · channel 9 " variant="primary" class="w-full" bodyClass="max-h-52 sm:max-h-60">
            <TerminalLine variant="system">// session established · uplink secure</TerminalLine>
            <TerminalLine variant="output">listening on 0.0.0.0:4409 …</TerminalLine>
            <TerminalLine variant="command">
              <TerminalPrompt cursor>astro telemetry push --live</TerminalPrompt>
            </TerminalLine>
            <TerminalLine variant="highlight">bundle graph optimized · 12 modules</TerminalLine>
            <TerminalLine variant="dim">hint: charts + Open-Meteo live on /dashboard</TerminalLine>
            <TerminalLine variant="error">warn: solar flux minor — recalibrate in 240s</TerminalLine>
            <TerminalLine variant="output">ok.</TerminalLine>
          </Terminal>
        </div>
      </div>
    </section>

    <footer
      class="mt-12 flex flex-col gap-4 border-t border-[var(--sf-border-subtle)] pt-8 sm:flex-row sm:items-center sm:justify-between"
    >
      <Text variant="label" class="text-sf-dim">
        <a class="text-sf-primary underline-offset-2 hover:underline" href="/">← Home</a>
        · <a class="text-sf-primary underline-offset-2 hover:underline" href="/settings">Settings</a>
      </Text>
      <Button variant="ghost" type="button" id="sf-reduced-motion-hint" class="!cursor-default" sound={false}>
        Respects reduced motion
      </Button>
    </footer>
  </AppShell>
</ScifiLayout>
