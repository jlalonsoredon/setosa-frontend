---
import ScifiLayout from "../layouts/ScifiLayout.astro";
import AppShell from "../components/shell/AppShell.astro";
import AppNav from "../components/shell/AppNav.astro";
import Text from "../components/core/Text.astro";
import AlertCenter from "../components/alertas/AlertCenter.tsx";
---

<ScifiLayout title="Centro de Alertas — Sci-Fi UI">
  <AppShell>
    <AppNav />
    <header class="space-y-3">
      <Text variant="label" class="text-sf-primary">Operaciones · Tráfico</Text>
      <h1
        class="font-sf-display text-4xl font-semibold tracking-[0.08em] text-sf-text sm:text-5xl lg:text-6xl normal-case"
      >
        Centro de recepción de alertas
      </h1>
      <p class="text-lg leading-relaxed text-sf-muted sm:text-xl">
        Recepción y evaluación de incidentes viales en tiempo real. Pulse
        <strong class="text-sf-text">Recibir nueva alerta</strong> para obtener el
        último incidente registrado, evalúe la gravedad y envíe las asistencias necesarias.
      </p>
    </header>

    <AlertCenter
      client:load
      apiBase={import.meta.env.PUBLIC_ALERT_API_URL ?? ""}
    />

    <footer class="mt-6 border-t border-[var(--sf-border-subtle)] py-6 pb-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="flex flex-col gap-2">
          <span class="font-sf-mono text-xs text-sf-muted">
            Proyecto realizado para el bootcamp de Data Science de
          </span>
          <img
            src="/logo-bootcamp.webp"
            alt="Logo bootcamp"
            class="opacity-90"
          />
        </div>
        <div class="flex flex-col gap-0.5 text-right">
          <span class="font-sf-mono text-xs text-sf-muted">Creado por:</span>
          <span class="font-sf-mono text-xs text-sf-dim">Fátima Goiri, Unai Riaño, Naia Merino,</span>
          <span class="font-sf-mono text-xs text-sf-dim">Eneko Ostolozaga, Jose Luis Alonso y Chiara López</span>
        </div>
      </div>
    </footer>
  </AppShell>
</ScifiLayout>
