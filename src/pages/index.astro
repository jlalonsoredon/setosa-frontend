---
import ScifiLayout from "../layouts/ScifiLayout.astro";
import AppShell from "../components/shell/AppShell.astro";
import AppNav from "../components/shell/AppNav.astro";
import Panel from "../components/core/Panel.astro";
import Text from "../components/core/Text.astro";

const ctaPrimary =
  "inline-flex min-h-10 items-center justify-center gap-2 rounded-sm border border-[var(--sf-border-strong)] bg-[color-mix(in_oklab,var(--sf-color-primary)_18%,var(--sf-bg-elevated))] px-5 py-2 font-sf-mono text-xs uppercase tracking-[0.2em] text-sf-text shadow-[0_0_0_1px_color-mix(in_oklab,var(--sf-color-primary)_25%,transparent),0_0_24px_var(--sf-glow-primary)] transition hover:shadow-[0_0_0_1px_var(--sf-color-primary),0_0_36px_var(--sf-glow-primary)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sf-primary active:scale-[0.98]";
const ctaSecondary =
  "inline-flex min-h-10 items-center justify-center gap-2 rounded-sm border border-[color-mix(in_oklab,var(--sf-color-secondary)_45%,transparent)] bg-[color-mix(in_oklab,var(--sf-color-secondary)_14%,var(--sf-bg-elevated))] px-5 py-2 font-sf-mono text-xs uppercase tracking-[0.2em] text-sf-text shadow-[0_0_20px_var(--sf-glow-secondary)] transition hover:shadow-[0_0_32px_var(--sf-glow-secondary)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sf-primary active:scale-[0.98]";
const ctaGhost =
  "inline-flex min-h-10 items-center justify-center gap-2 rounded-sm border border-[var(--sf-border-subtle)] bg-transparent px-5 py-2 font-sf-mono text-xs uppercase tracking-[0.2em] text-sf-muted transition hover:border-[var(--sf-border-strong)] hover:text-sf-text hover:shadow-[0_0_18px_var(--sf-glow-primary)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sf-primary active:scale-[0.98]";
---

<ScifiLayout title="Astro Scifi-UI">
  <AppShell>
    <AppNav />
    <section class="flex flex-col gap-10 pb-4 pt-4 sm:gap-14 sm:pt-8 lg:flex-row lg:items-center lg:gap-16">
      <div class="max-w-2xl flex-1 space-y-6">
        <Text variant="label" class="text-sf-primary">Astro 6 · Tailwind v4</Text>
        <h1
          class="font-sf-display text-3xl font-semibold tracking-[0.08em] text-sf-text sm:text-4xl lg:text-5xl normal-case"
        >
          Astro Scifi-UI
        </h1>
        <p class="text-base leading-relaxed text-sf-muted sm:text-lg">
          Static-first frames, HUD layers, terminals, and radar — with optional React only where charts, maps, or motion
          earn the bundle. Tune the shell globally, then ship your own routes on top.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/kit" class={ctaPrimary}>Explore kit</a>
          <a href="/settings" class={ctaSecondary}>Settings</a>
          <a href="/dashboard" class={ctaGhost}>Dashboard</a>
        </div>
      </div>
      <div class="grid flex-1 gap-3 sm:grid-cols-2 lg:max-w-md">
        <Panel variant="primary" glow class="sm:col-span-2">
          <Text variant="label" class="text-sf-secondary">Why Astro</Text>
          <p class="mt-2 text-sm leading-relaxed text-sf-muted">
            Prerender by default, islands when you opt in — same tokens and shell across every page.
          </p>
        </Panel>
        <Panel variant="secondary" class="border border-[var(--sf-border-subtle)]">
          <Text variant="label">HUD + radar</Text>
          <p class="mt-2 text-xs text-sf-dim">Composable overlays, no global state machine.</p>
        </Panel>
        <Panel variant="secondary" class="border border-[var(--sf-border-subtle)]">
          <Text variant="label">Live demos</Text>
          <p class="mt-2 text-xs text-sf-dim">Map, intel, charts — env flags trim weight.</p>
        </Panel>
      </div>
    </section>

    <section class="border-t border-[var(--sf-border-subtle)] py-12">
      <Text variant="heading" as="h2" class="mb-2 !text-base sm:!text-lg">Where to next</Text>
      <p class="mb-8 max-w-2xl text-sm text-sf-muted">
        Everything here is MIT-licensed source you can lift into your own project. Docs describe tokens, props, and
        third-party caveats.
      </p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a
          href="/kit"
          class="group rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-elevated)_85%,transparent)] p-5 transition hover:border-[var(--sf-border-strong)] hover:shadow-[0_0_24px_var(--sf-glow-primary)]"
        >
          <Text variant="label" class="text-sf-primary">Kit</Text>
          <p class="mt-2 font-sf-display text-sm uppercase tracking-[0.14em] text-sf-text">Components</p>
          <p class="mt-2 text-xs text-sf-dim">Panels, frames, HUD, terminal, radar samples.</p>
        </a>
        <a
          href="/settings"
          class="group rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-elevated)_85%,transparent)] p-5 transition hover:border-[var(--sf-border-strong)] hover:shadow-[0_0_24px_var(--sf-glow-primary)]"
        >
          <Text variant="label" class="text-sf-primary">Shell</Text>
          <p class="mt-2 font-sf-display text-sm uppercase tracking-[0.14em] text-sf-text">Settings</p>
          <p class="mt-2 text-xs text-sf-dim">Theme, appearance, overlays, motion, UI sound.</p>
        </a>
        <a
          href="/dashboard"
          class="group rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-elevated)_85%,transparent)] p-5 transition hover:border-[var(--sf-border-strong)] hover:shadow-[0_0_24px_var(--sf-glow-primary)]"
        >
          <Text variant="label" class="text-sf-primary">Data</Text>
          <p class="mt-2 font-sf-display text-sm uppercase tracking-[0.14em] text-sf-text">Dashboard</p>
          <p class="mt-2 text-xs text-sf-dim">uPlot + Open-Meteo sample series.</p>
        </a>
        <a
          href="/map"
          class="group rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-elevated)_85%,transparent)] p-5 transition hover:border-[var(--sf-border-strong)] hover:shadow-[0_0_24px_var(--sf-glow-primary)]"
        >
          <Text variant="label" class="text-sf-primary">Field</Text>
          <p class="mt-2 font-sf-display text-sm uppercase tracking-[0.14em] text-sf-text">Map</p>
          <p class="mt-2 text-xs text-sf-dim">MapLibre tactical view (optional via env).</p>
        </a>
        <a
          href="/intel"
          class="group rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-elevated)_85%,transparent)] p-5 transition hover:border-[var(--sf-border-strong)] hover:shadow-[0_0_24px_var(--sf-glow-primary)] sm:col-span-2 lg:col-span-1"
        >
          <Text variant="label" class="text-sf-primary">Intel</Text>
          <p class="mt-2 font-sf-display text-sm uppercase tracking-[0.14em] text-sf-text">Sensors</p>
          <p class="mt-2 text-xs text-sf-dim">Embed + optional in-browser CV (env).</p>
        </a>
      </div>
    </section>

    <footer class="border-t border-[var(--sf-border-subtle)] pt-8">
      <Text variant="label" class="text-sf-dim">
        Markdown docs ship in <code class="text-sf-muted">docs/</code> (architecture, components, tokens, third-party) ·
        MIT
      </Text>
    </footer>
  </AppShell>
</ScifiLayout>
