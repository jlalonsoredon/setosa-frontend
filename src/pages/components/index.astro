---
import ScifiLayout from "../../layouts/ScifiLayout.astro";
import AppShell from "../../components/shell/AppShell.astro";
import AppNav from "../../components/shell/AppNav.astro";
import DocsShell from "../../components/docs/DocsShell.astro";
import Panel from "../../components/core/Panel.astro";
import Text from "../../components/core/Text.astro";
import { getAllComponentDocEntries } from "../../data/component-docs";

const first = getAllComponentDocEntries()[0];
---

<ScifiLayout title="Components — Sci‑Fi UI">
  <AppShell>
    <AppNav />
    <DocsShell>
      <header class="mb-10 space-y-4">
        <Text variant="label" class="text-sf-primary">Documentation</Text>
        <Text variant="heading" glow class="max-w-2xl">
          Component catalog
        </Text>
        <p class="max-w-2xl text-sm leading-relaxed text-sf-muted">
          One page per primitive: a minimal live preview and a copy-ready snippet. Props and types stay in{" "}
          <code class="text-sf-primary">docs/components.md</code> in the repository.
        </p>
        <p class="max-w-2xl text-sm leading-relaxed text-sf-muted">
          For a dense, all-in-one playground, use the <a
            class="text-sf-primary underline decoration-[var(--sf-border-subtle)] underline-offset-2"
            href="/kit">Kit</a
          > page.
        </p>
      </header>

      <Panel variant="primary" glow class="max-w-xl">
        <Text variant="heading" as="h2" class="!text-base">Browse</Text>
        <p class="mt-2 text-sm text-sf-muted">Pick a component from the sidebar, or start with the first entry.</p>
        <p class="mt-6 flex flex-wrap gap-6 text-sm">
          <a
            class="font-sf-mono text-sf-primary underline decoration-[var(--sf-border-subtle)] underline-offset-2 transition hover:decoration-sf-primary"
            href={`/components/${first.slug}`}>Open {first.title} →</a
          >
          <a
            class="font-sf-mono text-sf-muted underline decoration-[var(--sf-border-subtle)] underline-offset-2 transition hover:text-sf-text hover:decoration-sf-primary"
            href="/kit">Open Kit →</a
          >
        </p>
      </Panel>
    </DocsShell>
  </AppShell>
</ScifiLayout>
