---
import ScifiLayout from "../../layouts/ScifiLayout.astro";
import AppShell from "../../components/shell/AppShell.astro";
import AppNav from "../../components/shell/AppNav.astro";
import DocsShell from "../../components/docs/DocsShell.astro";
import Text from "../../components/core/Text.astro";
import CodeBlock from "../../components/docs/CodeBlock.astro";
import ComponentDemo from "../../components/docs/ComponentDemo.astro";
import { getAllComponentDocEntries, getComponentDocBySlug } from "../../data/component-docs";

export function getStaticPaths() {
  return getAllComponentDocEntries().map((e) => ({ params: { slug: e.slug } }));
}

const slug = Astro.params.slug ?? "";
const entry = getComponentDocBySlug(slug);

if (!entry) {
  return Astro.redirect("/components");
}
---

<ScifiLayout title={`${entry.title} — Components`}>
  <AppShell>
    <AppNav />
    <DocsShell>
      <article class="space-y-8">
        <header class="space-y-2">
          <Text variant="label" class="text-sf-primary">Components</Text>
          <Text variant="heading" as="h1" glow class="!text-2xl sm:!text-3xl">
            {entry.title}
          </Text>
          <p class="max-w-2xl text-sm leading-relaxed text-sf-muted">{entry.description}</p>
        </header>

        <section class="space-y-3" aria-label="Live preview">
          <Text variant="label" class="text-sf-dim">
            Preview
          </Text>
          <div
            class="overflow-hidden rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-elevated)_55%,transparent)] p-6 shadow-[inset_0_1px_0_color-mix(in_oklab,white_5%,transparent)]"
          >
            <ComponentDemo slug={entry.slug} />
          </div>
        </section>

        <section class="space-y-3" aria-label="Code example">
          <Text variant="label" class="text-sf-dim">
            Example
          </Text>
          <CodeBlock code={entry.code} lang="astro" />
        </section>
      </article>
    </DocsShell>
  </AppShell>
</ScifiLayout>
