---
import ScifiLayout from "../layouts/ScifiLayout.astro";
import AppShell from "../components/shell/AppShell.astro";
import AppNav from "../components/shell/AppNav.astro";
import Panel from "../components/core/Panel.astro";
import Text from "../components/core/Text.astro";
import HudReadout from "../components/hud/HudReadout.astro";
import TacticalMap from "../components/map/TacticalMap.tsx";

const mapEnabled = import.meta.env.PUBLIC_FEATURE_MAP !== "false";
---

<ScifiLayout title="Tactical map — Sci‑Fi UI">
  <AppShell>
    <AppNav />
    <header class="space-y-2">
      <Text variant="label" class="text-sf-primary">Operations</Text>
      <Text variant="heading" glow class="text-xl sm:text-2xl">Surface grid · global waypoints</Text>
      <p class="max-w-3xl text-sm text-sf-muted">
        MapLibre GL with raster basemaps (OSM, Carto, OpenTopoMap). Switch <strong class="text-sf-text">basemap</strong
        > mode or <strong class="text-sf-text">city</strong> waypoints — demo only; confirm tile provider terms for
        production.
      </p>
    </header>

    <div class="grid min-h-0 flex-1 gap-6 lg:grid-cols-[1fr_16rem] xl:grid-cols-[1fr_18rem]">
      {
        mapEnabled ? (
          <>
            <TacticalMap client:visible initialCityId="berlin" class="min-w-0" />
            <aside class="flex flex-col gap-4">
              <Panel variant="secondary" glow class="h-min">
                <Text variant="heading" as="h2" class="mb-4 !text-sm">HUD strip</Text>
                <div class="space-y-4">
                  <HudReadout>
                    <span slot="label">Grid</span>
                    OSM-RASTER
                  </HudReadout>
                  <HudReadout align="right">
                    <span slot="label">Link</span>
                    nominal
                  </HudReadout>
                  <Text variant="label" class="text-sf-dim">
                    Pan and zoom update coordinates from the live map state.
                  </Text>
                </div>
              </Panel>
              <Panel variant="primary" class="h-min border-[var(--sf-border-subtle)]">
                <Text variant="label" class="text-sf-dim">Attribution appears on the map canvas (MapLibre + OSM).</Text>
              </Panel>
            </aside>
          </>
        ) : (
          <Panel variant="secondary" glow class="min-h-[min(50vh,24rem)] max-w-2xl">
            <Text variant="heading" as="h2" class="mb-3 !text-sm">Map demo disabled</Text>
            <p class="text-sm leading-relaxed text-sf-muted">
              This build omits MapLibre (<code class="text-sf-primary">PUBLIC_FEATURE_MAP=false</code>). Set the variable
              in <code class="text-sf-primary">.env</code> or remove it to restore the tactical map. See the project README
              and <code class="text-sf-primary">.env.example</code>.
            </p>
          </Panel>
        )
      }
    </div>
  </AppShell>
</ScifiLayout>
