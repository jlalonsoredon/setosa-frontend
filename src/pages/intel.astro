---
import ScifiLayout from "../layouts/ScifiLayout.astro";
import AppShell from "../components/shell/AppShell.astro";
import AppNav from "../components/shell/AppNav.astro";
import Panel from "../components/core/Panel.astro";
import Text from "../components/core/Text.astro";
import Button from "../components/core/Button.astro";
import Frame from "../components/core/Frame.astro";
import IntelObjectDetector from "../components/intel/IntelObjectDetector.tsx";

const intelMlEnabled = import.meta.env.PUBLIC_FEATURE_INTEL_ML !== "false";

/** rnXIjl_Rzy4 — embed only; mock UI still applies to “recognition” */
const INTEL_YOUTUBE_VIDEO_ID = "rnXIjl_Rzy4";
/** `controls=0` hides the default player chrome; YouTube may still show a minimal tap overlay (e.g. unmute). */
const intelYoutubeEmbedSrc = `https://www.youtube.com/embed/${INTEL_YOUTUBE_VIDEO_ID}?si=NKobSDCRfU3l8SKn&autoplay=1&mute=1&playsinline=1&rel=0&controls=0`;
---

<ScifiLayout title="Intel deck (mock) — Sci‑Fi UI">
  <AppShell>
    <AppNav />
    <header class="space-y-2">
      <Text variant="label" class="text-sf-secondary">Spectral analysis · UI mock</Text>
      <Text variant="heading" glow class="text-xl sm:text-2xl">Recognition console</Text>
      <p class="max-w-3xl text-sm text-sf-muted">
        The <strong class="text-sf-text">YouTube</strong> panel and decorative overlays are for layout; the{" "}
        <strong class="text-sf-text">“Run scan”</strong> meter is still simulated. For{" "}
        <strong class="text-sf-text">real</strong> object detection, use the local sensor block below (webcam or video
        file — runs COCO-SSD in your browser; nothing is uploaded).
      </p>
    </header>

    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <Frame variant="primary" glow class="min-w-0">
        <div class="sf-frame-content-inset">
          <Text variant="label" class="mb-3 text-sf-primary">Optical feed (YouTube)</Text>
          <div
            id="sf-intel-feed"
            class="relative aspect-video w-full overflow-hidden rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_90%,transparent)]"
          >
            <iframe
              id="sf-intel-feed-embed"
              class="absolute inset-0 z-0 h-full w-full border-0"
              src={intelYoutubeEmbedSrc}
              title="YouTube video player"
              width="1280"
              height="720"
              loading="eager"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              referrerpolicy="strict-origin-when-cross-origin"
            />
            <div
              class="pointer-events-none absolute inset-0 z-[1] bg-[radial-gradient(ellipse_at_30%_20%,color-mix(in_oklab,var(--sf-color-primary)_12%,transparent),transparent_55%),radial-gradient(ellipse_at_70%_80%,color-mix(in_oklab,var(--sf-color-secondary)_10%,transparent),transparent_50%),linear-gradient(160deg,color-mix(in_oklab,var(--sf-bg-deep)_35%,transparent),transparent_45%)]"
              aria-hidden="true"
            >
            </div>
            <div
              class="sf-intel-feed-pulse pointer-events-none absolute left-[14%] top-[18%] z-[2] h-[20%] w-[26%] border-2 border-[var(--sf-color-primary)] opacity-90 shadow-[0_0_12px_var(--sf-glow-primary)]"
              aria-hidden="true"
            >
            </div>
            <div
              class="sf-intel-feed-pulse pointer-events-none absolute bottom-[22%] right-[12%] z-[2] h-[14%] w-[18%] border-2 border-[var(--sf-color-secondary)] opacity-80 shadow-[0_0_10px_var(--sf-glow-secondary)]"
              style="animation-delay: 0.4s"
              aria-hidden="true"
            >
            </div>
            <p class="sr-only">
              Embedded YouTube live stream for demonstration. Classification overlays are decorative only.
            </p>
            <div
              class="pointer-events-none absolute bottom-2 left-2 z-[2] flex flex-wrap gap-2 rounded-sm bg-[color-mix(in_oklab,black_55%,transparent)] px-2 py-1 text-[0.6rem] uppercase tracking-[0.15em] text-[var(--sf-text-muted)]"
            >
              <span>SIM OVERLAY</span>
              <span class="text-[var(--sf-text-dim)]">· youtube</span>
            </div>
          </div>
          <p class="mt-2 text-[0.65rem] leading-relaxed text-sf-dim">
            Autoplay is muted by browser policy — use the player controls to hear audio.
          </p>
          <div class="mt-4 flex flex-wrap items-center gap-4">
            <div>
              <Text variant="label" class="mb-1">Pipeline</Text>
              <p
                id="sf-intel-state"
                class="font-sf-mono text-sm text-sf-primary"
                aria-live="polite"
                aria-atomic="true"
              >
                IDLE
              </p>
            </div>
            <div class="min-w-[12rem] flex-1">
              <Text variant="label" class="mb-1">Confidence (mock)</Text>
              <div class="h-2 overflow-hidden rounded-sm bg-[color-mix(in_oklab,var(--sf-bg-deep)_80%,transparent)]">
                <div
                  id="sf-intel-confidence-bar"
                  class="h-full bg-[linear-gradient(90deg,var(--sf-color-primary),var(--sf-color-secondary))] transition-[width] duration-300"
                  style="width: 0%"
                >
                </div>
              </div>
              <p id="sf-intel-confidence-label" class="mt-1 font-sf-mono text-xs text-sf-dim">0%</p>
            </div>
            <Button variant="primary" type="button" id="sf-intel-scan">Run scan</Button>
          </div>
        </div>
      </Frame>

      <div class="flex min-w-0 flex-col gap-4">
        <Panel variant="secondary" glow>
          <Text variant="heading" as="h2" class="mb-3 !text-sm">Event log</Text>
          <div
            id="sf-intel-log"
            role="region"
            aria-label="Event log"
            aria-live="polite"
            aria-relevant="additions"
            class="max-h-[min(52vh,28rem)] min-h-[12rem] overflow-y-auto rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-deep)_75%,transparent)] p-3"
          >
            <div class="font-sf-mono text-[0.7rem] text-sf-dim">// awaiting operator command</div>
          </div>
        </Panel>
      </div>
    </div>

    <Panel variant="primary" glow class="mt-4">
      <Text variant="heading" as="h2" class="mb-4 !text-base">Local sensor · COCO-SSD</Text>
      {
        intelMlEnabled ? (
          <IntelObjectDetector client:only="react" />
        ) : (
          <p class="text-sm leading-relaxed text-sf-muted">
            This block is disabled for this build (<code class="text-sf-primary">PUBLIC_FEATURE_INTEL_ML=false</code>
            ). Re-enable it in <code class="text-sf-primary">.env</code> to load TensorFlow.js and run in-browser detection. See the
            project README and <code class="text-sf-primary">.env.example</code> at the repo root.
          </p>
        )
      }
    </Panel>

    <script>
      import "../scripts/intel-demo";
    </script>
  </AppShell>
</ScifiLayout>
