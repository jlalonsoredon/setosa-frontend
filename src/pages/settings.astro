---
import ScifiLayout from "../layouts/ScifiLayout.astro";
import AppShell from "../components/shell/AppShell.astro";
import AppNav from "../components/shell/AppNav.astro";
import Panel from "../components/core/Panel.astro";
import Text from "../components/core/Text.astro";
import Button from "../components/core/Button.astro";
---

<ScifiLayout title="Settings — Sci‑Fi UI">
  <AppShell>
    <AppNav />
    <header class="mb-8 space-y-3">
      <Text variant="label" class="text-sf-primary">Preferences</Text>
      <Text variant="heading" glow class="max-w-2xl">Global settings</Text>
      <p class="max-w-2xl text-sm leading-relaxed text-sf-muted">
        Theme, appearance, overlays, motion, and UI sound are stored in this browser under{" "}
        <code class="text-sf-primary">sf:settings</code>. They apply on every route that uses the shell.
      </p>
    </header>

    <Panel variant="secondary" glow id="sf-settings-root">
      <Text variant="heading" as="h2" class="mb-4 !text-base sm:!text-lg">Controls</Text>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="space-y-3">
          <Text variant="label">Color theme</Text>
          <div class="flex flex-wrap gap-2" id="sf-theme-switcher" role="group" aria-label="Color theme">
            {
              [
                { id: "default", label: "Synthwave" },
                { id: "nebula", label: "Nebula" },
                { id: "ember", label: "Ember" },
                { id: "matrix", label: "Matrix" },
                { id: "void", label: "Void" },
              ].map((t) => (
                <button
                  type="button"
                  class="rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-elevated)_90%,transparent)] px-3 py-1.5 text-[0.65rem] uppercase tracking-[0.18em] text-sf-muted transition hover:border-[var(--sf-border-strong)] hover:text-sf-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--sf-color-primary)]"
                  data-theme-choice={t.id}
                  data-sf-sound-hover
                  data-sf-sound-click
                >
                  {t.label}
                </button>
              ))
            }
          </div>
        </div>
        <div class="space-y-4">
          <Text variant="label">Audio</Text>
          <label class="flex cursor-pointer items-center gap-2 text-xs uppercase tracking-[0.2em] text-sf-muted">
            <input id="sf-settings-sound" type="checkbox" class="accent-[var(--sf-color-primary)]" />
            Enable UI sounds
          </label>
          <div class="space-y-1">
            <label for="sf-settings-volume" class="text-[0.65rem] uppercase tracking-[0.18em] text-sf-dim">
              Volume
            </label>
            <input
              id="sf-settings-volume"
              type="range"
              min="0"
              max="100"
              class="w-full accent-[var(--sf-color-primary)]"
            />
          </div>
          <Button variant="ghost" type="button" id="sf-settings-test-sound" class="!text-[0.65rem]" sound={false}>
            Test confirm tone
          </Button>
          <p class="text-[0.65rem] leading-relaxed text-sf-dim">
            Browsers may require a tap or click before audio unlocks; use test tone after enabling.
          </p>
        </div>
      </div>
      <div class="mt-6 space-y-3 border-t border-[var(--sf-border-subtle)] pt-6">
        <Text variant="label">Appearance</Text>
        <div class="flex flex-wrap gap-2" role="group" aria-label="Display appearance">
          {
            [
              { id: "default", label: "Default" },
              { id: "high-contrast", label: "High contrast" },
              { id: "light", label: "Light" },
            ].map((a) => (
              <button
                type="button"
                class="rounded-sm border border-[var(--sf-border-subtle)] bg-[color-mix(in_oklab,var(--sf-bg-elevated)_90%,transparent)] px-3 py-1.5 text-[0.65rem] uppercase tracking-[0.18em] text-sf-muted transition hover:border-[var(--sf-border-strong)] hover:text-sf-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--sf-color-primary)]"
                data-appearance-choice={a.id}
                data-sf-sound-hover
                data-sf-sound-click
              >
                {a.label}
              </button>
            ))
          }
        </div>
      </div>
      <div class="mt-6 grid gap-4 border-t border-[var(--sf-border-subtle)] pt-6 sm:grid-cols-2">
        <label class="flex cursor-pointer items-center gap-2 text-xs text-sf-muted">
          <input id="sf-settings-scanlines" type="checkbox" class="accent-[var(--sf-color-primary)]" />
          Scanlines overlay
        </label>
        <label class="flex cursor-pointer items-center gap-2 text-xs text-sf-muted">
          <input id="sf-settings-grain" type="checkbox" class="accent-[var(--sf-color-primary)]" />
          HUD grain / noise
        </label>
        <label class="flex cursor-pointer items-center gap-2 text-xs text-sf-muted">
          <input id="sf-settings-vignette" type="checkbox" class="accent-[var(--sf-color-primary)]" />
          Vignette
        </label>
        <label class="flex cursor-pointer items-center gap-2 text-xs text-sf-muted">
          <input id="sf-settings-animations" type="checkbox" class="accent-[var(--sf-color-primary)]" />
          Interface motion
        </label>
      </div>
    </Panel>

    <footer
      class="mt-12 flex flex-col gap-4 border-t border-[var(--sf-border-subtle)] pt-8 sm:flex-row sm:items-center sm:justify-between"
    >
      <Text variant="label" class="text-sf-dim">
        <a class="text-sf-primary underline-offset-2 hover:underline" href="/">← Home</a>
        · <a class="text-sf-primary underline-offset-2 hover:underline" href="/kit">Component kit</a>
      </Text>
      <Button variant="ghost" type="button" id="sf-reduced-motion-hint" class="!cursor-default" sound={false}>
        Respects reduced motion
      </Button>
    </footer>
  </AppShell>
</ScifiLayout>
